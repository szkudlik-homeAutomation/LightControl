config NODE_SCAN_EEPROM_STATUS_TASK
    bool "Enable Node Scan Task with Eeprom statuses"
	default n
    select WORKER_PROCESS
    select TLE8457_COMM_LIB

config SYSTEM_STATUS_SENSOR_INSTANCE
	bool "Enable an instanve of system status sensor sending data to central node"
	default y
	select SENSORS
	select SYSTEM_STATUS_SENSOR
	imply SENSOR_SEND_EVENTS_USING_SERIAL
	help
		sensors IDs are equal to node ID
	

